import streamlit as st
import pandas as pd
import os, smtplib, time, io
from email.mime.text import MIMEText
from email.mime.multipart import MIMEMultipart
from email.mime.application import MIMEApplication

# הגדרות דף - שינוי שם המערכת בלשונית הדפדפן
st.set_page_config(page_title="TMC Billing System", layout="centered")

# כותרת ראשית
st.title("TMC Billing System")
st.write("---")

# חלק 1: הגדרות חודש ונתיבים (מותאם לעבודה מול Google Drive ב-Colab)
st.header("1. Configuration & Folders")
col1, col2 = st.columns(2)

with col1:
    current_month_year = st.text_input("Current Month & Year", value="March 2024")
with col2:
    # נתיב לקובץ האקסל המרכזי
    sheet_path = st.text_input("Database Path (Excel)", value="/content/drive/MyDrive/Emails and Company Arbitrip.xlsx")

# נתיב תיקיית האב שבה נמצאות תיקיות החברות
base_month_path = st.text_input("Base Invoices Path", value=f"/content/drive/MyDrive/Invoices_Folders/{current_month_year}/")

st.write("---")

# חלק 2: פרטי שולח והסבר סיסמה
st.header("2. Sender Details")

user_mail = st.text_input("Your Gmail Address:", value="galo@arbitrip.com")
user_pass = st.text_input("App Password:", type="password")

# רכיב מתקפל עם הסבר מפורט
with st.expander("🔑 How to create an App Password for TMC System?"):
    st.markdown("""
    To send emails via Gmail, you need a unique **App Password**. 
    *Standard login passwords will not work.*
    
    1. Go to your [**Google Account Security**](https://myaccount.google.com/security).
    2. Make sure **2-Step Verification** is turned **ON**.
    3. Scroll down or search for **'App passwords'**.
    4. Select an app name (e.g., "TMC Billing") and click **Create**.
    5. Copy the **16-character code** (without spaces) and paste it in the field above.
    """)

email_subject_template = st.text_input("Email Subject Base:", value="Invoice Payment Due")

st.write("---")

# פונקציות לוגיקה
def find_files_for_company(company_name, base_path):
    """מחפש PDF ואקסל בתיקיית החברה בדרייב"""
    folder_path = os.path.join(base_path, company_name)
    pdf_file, excel_file = None, None
    
    if not os.path.exists(folder_path):
        return None, None, folder_path

    for filename in os.listdir(folder_path):
        lower_name = filename.lower()
        full_path = os.path.join(folder_path, filename)
        if lower_name.endswith('.pdf') and not pdf_file:
            pdf_file = full_path
        elif (lower_name.endswith('.xlsx') or lower_name.endswith('.xls')) and not excel_file:
            excel_file = full_path
    return pdf_file, excel_file, folder_path

# כפתור שליחה
if st.button("Start Sending Invoices", use_container_width=True):
    if user_mail and user_pass:
        try:
            # קריאת נתוני החברות מהאקסל
            df = pd.read_excel(sheet_path)
            prog = st.progress(0)
            status = st.empty()
            
            # התחברות לשרת Gmail
            server = smtplib.SMTP("smtp.gmail.com", 587)
            server.starttls()
            server.login(user_mail.strip(), user_pass.replace(" ", ""))
            
            success_count = 0
            total_rows = len(df)

            for i, row in df.iterrows():
                company = str(row.iloc[0]).strip()
                emails = [e.strip() for e in str(row.iloc[1]).split(',') if '@' in e]
                day_of_month = str(row.iloc[2]).strip() if len(row.columns) > 2 else "10"
                due_date = f"{day_of_month} {current_month_year}"
                
                # איתור קבצים
                pdf_path, excel_path, folder_path = find_files_for_company(company, base_month_path)
                
                if pdf_path and excel_path:
                    msg = MIMEMultipart()
                    msg['From'] = user_mail
                    msg['To'] = ", ".join(emails)
                    msg['Subject'] = f"{email_subject_template} ({due_date}) - {company}"
                    
                    body = f"Hi,\n\nAttached is the detailed report and the relevant invoice for {company}.\n\nPayment is due by {due_date}.\n\nBest Regards,\nTMC Billing Team"
                    msg.attach(MIMEText(body, 'plain'))
                    
                    # צירוף הקבצים שנמצאו
                    for path in [pdf_path, excel_path]:
                        with open(path, "rb") as f:
                            part = MIMEApplication(f.read(), Name=os.path.basename(path))
                            part['Content-Disposition'] = f'attachment; filename="{os.path.basename(path)}"'
                            msg.attach(part)
                    
                    server.sendmail(user_mail, emails, msg.as_string())
                    success_count += 1
                    status.text(f"✅ Sent to: {company}")
                else:
                    st.warning(f"⚠️ Files missing for {company} in folder: {folder_path}")

                prog.progress((i + 1) / total_rows)
                time.sleep(0.2)

            server.quit()
            st.success(f"Successfully sent {success_count} emails!")
            st.balloons()

        except Exception as e:
            st.error(f"Error occurred: {e}")
    else:
        st.warning("Missing Email or App Password.")
